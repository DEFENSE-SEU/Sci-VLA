<mujoco model="3Dprinter">

    <compiler angle="radian"
              coordinate="local"
              meshdir="../../assets/3Dprinter"/>

    <asset>
        <mesh name="printer_body_mesh" file="body.obj" scale="0.5 0.5 0.5"/>
        <mesh name="handle_mesh"       file="handle.obj" scale="0.5 0.5 0.5"/>
    </asset>

    <worldbody>
        <body name="printer" quat="0.7071 0.7071 0 0">

            <!-- 机箱 -->
            <geom name="printer_body"
                  type="mesh"
                  mesh="printer_body_mesh"/>

            <!-- 把手 -->
            <body name="handle">
                  
                <joint name="handle_hinge"
                       type="hinge"
                       axis="0 1 0"
                       pos="-0.45 -0.4 0.55"
                       range="-15 0"
                       limited="true"
                       frictionloss="0.05"
                       damping="1.0"/>

                <geom name="handle_geom"
                      type="mesh"
                      mesh="handle_mesh"/>
            </body>
        
        </body>
    </worldbody>
    <actuator>
    <position name="handle_act"
              joint="handle_hinge"
              kp="2"/>
    </actuator>

</mujoco>
