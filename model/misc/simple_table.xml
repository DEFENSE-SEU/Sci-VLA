<?xml version="1.0" encoding="utf-8"?>
<mujoco model="simple table">
    <compiler angle="radian" />

    <default>
        <default class="vention">
            <geom conaffinity="0" contype="0" group="1"/>
            <default class="vention_collision">
                <geom conaffinity="1" condim="3" contype="0" group="3" margin="0.001" rgba=".4 .5 .6 1"/>
            </default>
        </default>
    </default>

    <asset>
        <material name="vention_black" rgba="0.05 0.05 0.1 1" reflectance="0" shininess=".5"  />
        <material name="vention_white" rgba="0.4 0.4 0.4 1" reflectance="0." shininess=".1"  />
        <material name="vention_blue" rgba=".14 .30 .52 1" reflectance="10" shininess=".1"  />
    </asset>

    <worldbody>
        <body name="vention table" childclass="vention">
            <!-- leg floor pads -->
            <geom type="cylinder" size="0.040 0.010" pos="-1.17 -.766 0.010" material="vention_black"/>
            <geom type="cylinder" size="0.040 0.010" pos="1.17 -.766 0.010" material="vention_black"/>
            <geom type="cylinder" size="0.040 0.010" pos="-1.17 0.766 0.010" material="vention_black"/>
            <geom type="cylinder" size="0.040 0.010" pos="1.17 0.766 0.010" material="vention_black"/>

            <!-- leg pad stems -->
            <geom type="cylinder" size="0.010 0.020" pos="-1.17 -.766 0.030" material="vention_black"/>
            <geom type="cylinder" size="0.010 0.020" pos="1.17 -.766 0.030" material="vention_black"/>
            <geom type="cylinder" size="0.010 0.020" pos="-1.17 0.766 0.030" material="vention_black"/>
            <geom type="cylinder" size="0.010 0.020" pos="1.17 0.766 0.030" material="vention_black"/>

            <!-- legs -->
            <geom type="box" size="0.023 0.023 .387" pos="-1.17 -.766 0.435" material="vention_blue"/>
            <geom type="box" size="0.023 0.023 .387" pos="1.17 -.766 0.435" material="vention_blue"/>
            <geom type="box" size="0.023 0.023 .387" pos="-1.17 0.766 0.435" material="vention_blue"/>
            <geom type="box" size="0.023 0.023 .387" pos="1.17 0.766 0.435" material="vention_blue"/>

            <!-- middle legs -->
            <geom type="box" size="0.023 0.023 .337" pos="0 0.754 0.440" material="vention_blue"/>
            <geom type="box" size="0.023 0.023 .337" pos="0 -0.754 0.440" material="vention_blue"/>

            <!-- top board -->
            <geom type="box" size="2.612 1.640 0.023" pos="0 0 0.801" material="vention_white"/>
            <geom type="box" size="2.612 1.640 0.023" pos="0 0 0.790" material="vention_blue"/>

            <!-- bottom board -->
            <geom type="box" size="1.204 0.798 0.005" pos="0 0 0.150" material="vention_white"/>
            <geom type="box" size="1.206 0.800 0.023" pos="0 0 0.124" material="vention_blue"/>

            <!-- collision -->
            <geom type="box" size="1.206 0.800 0.411" pos="0 0 0.413" class="vention_collision"/>
        </body>
    </worldbody>

</mujoco>